<?xml version="1.0" encoding="UTF-8"?>
<!--
  multithreaded-job.xml
  =====================
  Processes WORK_ITEM rows in parallel using a fixed thread pool.

  Architecture
  ────────────
  This job uses a MULTI-THREADED STEP (not partitioning).
  Multiple chunk threads run concurrently inside a single step execution,
  each processing an independent page of items from the reader.

    processWorkItemsStep  ──next──►  statisticsAndEmailStep
      (multi-threaded chunk)               (tasklet)

  Why JdbcPagingItemReader?
  ─────────────────────────
  JdbcCursorItemReader is NOT thread-safe — concurrent threads would
  corrupt the shared cursor. JdbcPagingItemReader is thread-safe because
  each thread fetches its own page of rows independently using OFFSET/FETCH.

  Thread count
  ────────────
  Controlled by batch.multithreaded.threadCount (default: 4).
  Each thread processes one chunk (page) at a time, so effective concurrency
  = min(threadCount, available pages).

  Datasource used
  ───────────────
  dataSource + transactionManager (primary) for both reader and writer.

  Run
  ───
    java -jar app.jar multithreaded-job
    ./multithreaded-job.sh
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:batch="http://www.springframework.org/schema/batch"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
               https://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/batch
               https://www.springframework.org/schema/batch/spring-batch.xsd">

    <!-- ================================================================
         Paging query provider — SQL Server dialect
         SqlPagingQueryProviderFactoryBean auto-selects the correct
         OFFSET/FETCH paging SQL for the connected database.
         NOT step-scoped: shared safely across threads (read-only metadata).

         ⚠ KNOWN LIMITATION — paging race condition with in-place status update
         ─────────────────────────────────────────────────────────────────────
         The WHERE clause reads WHERE status = 'PENDING'. The writer marks
         processed rows status = 'PROCESSED'. With OFFSET/FETCH paging, as
         threads complete pages and shrink the result set, later pages shift —
         rows near page boundaries may be skipped and remain PENDING.
         This is acceptable for a sample/demo job with low row counts.
         For high-volume production use, replace this job with the partitioned
         pattern (partitioned-db-to-file-job.xml): split by id range so each
         worker's query is completely independent of other workers' writes.
         ================================================================ -->
    <bean id="workItemQueryProvider"
          class="org.springframework.batch.item.database.support.SqlPagingQueryProviderFactoryBean">
        <property name="dataSource"    ref="dataSource"/>
        <property name="selectClause"  value="SELECT id, payload, priority, status, created_at, processed_at"/>
        <property name="fromClause"    value="FROM WORK_ITEM"/>
        <property name="whereClause"   value="WHERE status = 'PENDING'"/>
        <!-- sortKey MUST be unique to guarantee consistent paging across threads -->
        <property name="sortKey"       value="id"/>
    </bean>

    <!-- ================================================================
         Reader — JdbcPagingItemReader (thread-safe)
         Step-scoped: each step execution gets its own reader state.
         pageSize should equal commit-interval for efficiency.
         saveState=false: multi-threaded steps cannot checkpoint per-thread
         reader positions reliably. Prevents the ChunkMonitor
         "ItemStream was opened in a different thread" warning.
         On restart the reader re-queries from page 0.
         ================================================================ -->
    <bean id="workItemReader"
          class="org.springframework.batch.item.database.JdbcPagingItemReader"
          scope="step">
        <property name="dataSource"     ref="dataSource"/>
        <property name="queryProvider"  ref="workItemQueryProvider"/>
        <property name="pageSize"       value="${batch.multithreaded.pageSize:50}"/>
        <property name="rowMapper">
            <bean class="com.example.batch.multithreaded.WorkItemRowMapper"/>
        </property>
        <property name="saveState"      value="false"/>
    </bean>

    <!-- ================================================================
         Processor — stateless; safe to share across all chunk threads
         ================================================================ -->
    <bean id="workItemProcessor"
          class="com.example.batch.multithreaded.WorkItemProcessor"/>

    <!-- ================================================================
         Writer — JdbcBatchItemWriter (thread-safe: each chunk runs
         in its own transaction on its own DB connection from the pool)
         Updates the WORK_ITEM row with PROCESSED status + timestamp.
         ================================================================ -->
    <bean id="workItemWriter"
          class="org.springframework.batch.item.database.JdbcBatchItemWriter">
        <property name="dataSource" ref="dataSource"/>
        <property name="sql">
            <value>
                UPDATE WORK_ITEM
                SET    status       = :status,
                       payload      = :payload,
                       processed_at = :processedAt
                WHERE  id = :id
            </value>
        </property>
        <property name="itemSqlParameterSourceProvider">
            <bean class="org.springframework.batch.item.database.BeanPropertyItemSqlParameterSourceProvider"/>
        </property>
    </bean>

    <!-- ================================================================
         Thread pool — fixed size controls max parallelism.
         queueCapacity=0 uses a SynchronousQueue which applies backpressure:
         the step blocks submitting new chunks if all threads are busy.
         ================================================================ -->
    <bean id="stepTaskExecutor" parent="abstractStepTaskExecutor">
        <property name="corePoolSize"     value="${batch.multithreaded.threadCount:4}"/>
        <property name="maxPoolSize"      value="${batch.multithreaded.threadCount:4}"/>
        <property name="threadNamePrefix" value="batch-worker-"/>
    </bean>

    <!-- ================================================================
         JOB DEFINITION
         ================================================================ -->
    <batch:job id="multithreadedJob" restartable="true">

        <batch:validator ref="batchJobParameterValidator"/>

        <batch:listeners>
            <batch:listener ref="jobStatisticsListener"/>
        </batch:listeners>

        <!-- ============================================================
             STEP 1 — Multi-threaded chunk step
             task-executor wires the ThreadPoolTaskExecutor so each
             chunk is dispatched to a worker thread.
             ============================================================ -->
        <batch:step id="processWorkItemsStep" next="statisticsAndEmailStep">
            <batch:tasklet transaction-manager="transactionManager"
                           task-executor="stepTaskExecutor">

                <batch:chunk reader="workItemReader"
                             processor="workItemProcessor"
                             writer="workItemWriter"
                             commit-interval="${batch.multithreaded.commitInterval:50}"
                             skip-limit="20"
                             retry-limit="3">

                    <!-- PERMANENT: bad payload — skip without retry -->
                    <batch:skippable-exception-classes>
                        <batch:include class="java.lang.IllegalArgumentException"/>
                        <batch:include class="java.lang.IllegalStateException"/>
                        <batch:include class="org.springframework.dao.DataIntegrityViolationException"/>
                        <batch:include class="java.sql.SQLTransientException"/>
                        <batch:include class="org.springframework.dao.TransientDataAccessException"/>
                    </batch:skippable-exception-classes>

                    <!-- TRANSIENT: retry DB errors up to retry-limit -->
                    <batch:retryable-exception-classes>
                        <batch:include class="java.sql.SQLTransientException"/>
                        <batch:include class="org.springframework.dao.TransientDataAccessException"/>
                    </batch:retryable-exception-classes>

                </batch:chunk>

                <batch:listeners>
                    <batch:listener ref="stepStatisticsListener"/>
                    <batch:listener ref="stepErrorCollector"/>
                </batch:listeners>

            </batch:tasklet>
        </batch:step>

        <!-- STEP 2 (LAST) — Statistics report + email -->
        <batch:step id="statisticsAndEmailStep">
            <batch:tasklet ref="statisticsAndEmailTasklet"
                           transaction-manager="transactionManager"/>
        </batch:step>

    </batch:job>

</beans>
