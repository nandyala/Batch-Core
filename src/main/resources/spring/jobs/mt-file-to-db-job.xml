<?xml version="1.0" encoding="UTF-8"?>
<!--
  mt-file-to-db-job.xml
  =====================
  Multi-threaded variant of file-to-db-job.
  Reads a CSV transaction file using a SynchronizedItemStreamReader wrapping
  FlatFileItemReader, and writes to TRANSACTION_STAGING using JdbcBatchItemWriter
  (which is already thread-safe — each chunk runs its own batch INSERT/MERGE
  in its own transaction on its own pooled connection).

  Key design decisions
  ─────────────────────
  1. SynchronizedItemStreamReader wrapping FlatFileItemReader
     FlatFileItemReader maintains a single file channel and line counter —
     not thread-safe. Wrapping with SynchronizedItemStreamReader serialises
     each read() call so every line is claimed by exactly one thread and
     no line is skipped or double-read.

  2. saveState="false" on FlatFileItemReader
     In a multi-threaded step Spring Batch cannot track which thread was
     reading which line when a failure occurs, so checkpoint positions are
     unreliable. Setting saveState="false" disables position checkpointing.
     On restart the job re-reads the file from the beginning — safe because
     the MERGE writer is fully idempotent (upsert on transaction_id).

  3. JdbcBatchItemWriter — no synchronisation needed
     Each chunk runs its own batch MERGE in a separate transaction on a
     separate DB connection from the HikariCP pool. Concurrent writes to
     different rows are handled by SQL Server row-level locking.

  Job execution flow
  ──────────────────
    mtImportTransactionsStep  ──next──►  statisticsAndEmailStep
       (multi-threaded chunk)                 (tasklet)

  Required job parameters
  ───────────────────────
    batchDate=YYYY-MM-DD   — used to build the default input file path
                             (or pass inputFile=/full/path/to/file.csv)

  Input file path (in order of preference)
  ─────────────────────────────────────────
    1. inputFile=<absolute path> job parameter (explicit override)
    2. ${batch.filetodb.inputDir}/{batchDate}/transactions.csv

  Run
  ───
    java -jar app.jar mt-file-to-db-job  batchDate=2026-01-15
    ./mt-file-to-db-job.sh
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:batch="http://www.springframework.org/schema/batch"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
               https://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/batch
               https://www.springframework.org/schema/batch/spring-batch.xsd">

    <!-- ================================================================
         Reader (delegate) — FlatFileItemReader
         saveState="false": disables position checkpointing because a
         multi-threaded step cannot reliably track per-thread file positions.
         On restart the file is re-read from line 1 — the idempotent MERGE
         writer ensures no duplicate rows are inserted.
         NOT wired to the chunk directly — the SynchronizedItemStreamReader
         below wraps it.
         ================================================================ -->
    <bean id="mtTransactionFileReader"
          class="org.springframework.batch.infrastructure.item.file.FlatFileItemReader"
          scope="step">
        <constructor-arg
                  value="file:#{jobParameters['inputFile'] ?: '${batch.filetodb.inputDir}/' + jobParameters['batchDate'] + '/transactions.csv'}"/>
        <property name="linesToSkip" value="1"/>
        <!--
          saveState=false because in a multi-threaded step the reader's
          position is meaningless for restart — see class-level comment.
        -->
        <property name="saveState" value="false"/>
        <constructor-arg>
            <bean class="org.springframework.batch.infrastructure.item.file.mapping.DefaultLineMapper">
                <property name="lineTokenizer">
                    <bean class="org.springframework.batch.infrastructure.item.file.transform.DelimitedLineTokenizer">
                        <property name="delimiter" value=","/>
                        <property name="names"
                                  value="transaction_id,account_number,amount,transaction_type,transaction_date,description"/>
                    </bean>
                </property>
                <property name="fieldSetMapper">
                    <bean class="com.example.batch.filetodb.TransactionFieldSetMapper"/>
                </property>
            </bean>
        </constructor-arg>
    </bean>

    <!-- ================================================================
         Reader (thread-safe wrapper) — SynchronizedItemStreamReader
         Serialises read() calls so concurrent chunk threads each get a
         unique line. The underlying FlatFileItemReader is never accessed
         by more than one thread at a time.
         Step-scoped to match the delegate's scope.
         ================================================================ -->
    <bean id="mtTransactionSyncReader"
          class="org.springframework.batch.infrastructure.item.support.SynchronizedItemStreamReader"
          scope="step">
        <constructor-arg ref="mtTransactionFileReader"/>
    </bean>

    <!-- ================================================================
         Processor — stateless; safe to share across chunk threads
         ================================================================ -->
    <bean id="mtTransactionProcessor"
          class="com.example.batch.filetodb.TransactionProcessor"/>

    <!-- ================================================================
         Writer — JdbcBatchItemWriter (inherently thread-safe)
         Each chunk runs its own batched MERGE in its own transaction on its
         own HikariCP connection — SQL Server row-level locking handles
         concurrent writes to distinct rows without any extra synchronisation.
         The MERGE upsert on transaction_id ensures idempotent restarts.
         ================================================================ -->
    <bean id="mtTransactionWriter"
          class="org.springframework.batch.infrastructure.item.database.JdbcBatchItemWriter">
        <property name="dataSource" ref="dataSource"/>
        <property name="sql">
            <value>
                MERGE INTO TRANSACTION_STAGING AS target
                USING (SELECT :transactionId AS transaction_id) AS src
                   ON target.transaction_id = src.transaction_id
                WHEN MATCHED THEN
                    UPDATE SET
                        account_number   = :accountNumber,
                        amount           = :amount,
                        transaction_type = :transactionType,
                        transaction_date = :transactionDate,
                        description      = :description,
                        updated_at       = GETDATE()
                WHEN NOT MATCHED THEN
                    INSERT (transaction_id, account_number, amount,
                            transaction_type, transaction_date, description,
                            created_at, updated_at)
                    VALUES (:transactionId, :accountNumber, :amount,
                            :transactionType, :transactionDate, :description,
                            GETDATE(), GETDATE());
            </value>
        </property>
        <property name="itemSqlParameterSourceProvider">
            <bean class="org.springframework.batch.infrastructure.item.database.BeanPropertyItemSqlParameterSourceProvider"/>
        </property>
        <property name="assertUpdates" value="false"/>
    </bean>

    <!-- ================================================================
         Thread pool
         ================================================================ -->
    <bean id="mtFileToDbTaskExecutor" parent="abstractStepTaskExecutor">
        <property name="corePoolSize"     value="${batch.mtfiletodb.threadCount:4}"/>
        <property name="maxPoolSize"      value="${batch.mtfiletodb.threadCount:4}"/>
        <property name="threadNamePrefix" value="mt-file-db-"/>
    </bean>

    <!-- ================================================================
         JOB DEFINITION
         ================================================================ -->
    <batch:job id="mtFileToDbJob" restartable="true">

        <batch:validator ref="mtFileToDbJobParameterValidator"/>

        <batch:listeners>
            <batch:listener ref="jobStatisticsListener"/>
        </batch:listeners>

        <!-- ============================================================
             STEP 1 — Multi-threaded import: CSV → TRANSACTION_STAGING
             ============================================================ -->
        <batch:step id="mtImportTransactionsStep" next="statisticsAndEmailStep">
            <batch:tasklet transaction-manager="transactionManager"
                           task-executor="mtFileToDbTaskExecutor">

                <batch:chunk reader="mtTransactionSyncReader"
                             processor="mtTransactionProcessor"
                             writer="mtTransactionWriter"
                             commit-interval="${batch.mtfiletodb.commitInterval:200}"
                             skip-limit="100"
                             retry-limit="3">

                    <!-- PERMANENT: bad data in the file -->
                    <batch:skippable-exception-classes>
                        <batch:include class="java.lang.IllegalArgumentException"/>
                        <batch:include class="java.lang.IllegalStateException"/>
                        <batch:include class="org.springframework.batch.infrastructure.item.file.FlatFileParseException"/>
                        <batch:include class="org.springframework.dao.DataIntegrityViolationException"/>
                        <batch:include class="java.sql.SQLTransientException"/>
                        <batch:include class="org.springframework.dao.TransientDataAccessException"/>
                    </batch:skippable-exception-classes>

                    <!-- TRANSIENT: retry DB errors before counting as a skip -->
                    <batch:retryable-exception-classes>
                        <batch:include class="java.sql.SQLTransientException"/>
                        <batch:include class="org.springframework.dao.TransientDataAccessException"/>
                    </batch:retryable-exception-classes>

                </batch:chunk>

                <batch:listeners>
                    <batch:listener ref="stepStatisticsListener"/>
                    <batch:listener ref="stepErrorCollector"/>
                </batch:listeners>

            </batch:tasklet>
        </batch:step>

        <!-- STEP 2 (LAST) — Statistics report + email -->
        <batch:step id="statisticsAndEmailStep">
            <batch:tasklet ref="statisticsAndEmailTasklet"
                           transaction-manager="transactionManager"/>
        </batch:step>

    </batch:job>

    <!-- ================================================================
         Parameter validator
         ================================================================ -->
    <bean id="mtFileToDbJobParameterValidator"
          class="com.example.batch.support.BatchJobParameterValidator">
        <property name="requiredParams">
            <set>
                <value>batchDate</value>
            </set>
        </property>
    </bean>

</beans>
