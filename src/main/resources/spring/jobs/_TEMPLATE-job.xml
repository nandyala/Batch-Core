<?xml version="1.0" encoding="UTF-8"?>
<!--
  _TEMPLATE-job.xml
  =================
  DEVELOPER TEMPLATE — copy this file, rename it, then follow the TODO
  markers below to implement a new Spring Batch job.

  Steps to create a new job
  ──────────────────────────
    1.  Copy this file to spring/jobs/{your-job-name}-job.xml
    2.  Choose a template variant (A, B, or C) and delete the others
    3.  Fill in each TODO section
    4.  No registration needed — framework resolves spring/jobs/{slug}.xml automatically
    5.  Add job properties to application.properties
    6.  Add a launch script in src/main/scripts/{your-job-name}-job.sh
    7.  Add the job to validate-config.sh JOB_PARAMS map

  Template variants
  ─────────────────
  A — Single-threaded chunk  (file→DB, DB→file, DB→DB)         [safest default]
  B — Multi-threaded chunk   (parallelise inside one step)      [needs thread-safe reader/writer]
  C — Partitioned step       (independent sub-steps by id range)[best restart isolation]

  Which variant should I choose?
  ────────────────────────────────────────────────────────────────
  Reader type            Recommended approach
  ─────────────────────  ────────────────────
  JdbcCursorItemReader   A (single) or C (partitioned) — cursor is NOT thread-safe
  JdbcPagingItemReader   A, B, or C — paging reader IS thread-safe
  FlatFileItemReader     A (single) or B (with SynchronizedItemStreamReader)
  ─────────────────────  ────────────────────

  Retry / Skip taxonomy  (reuse across all variants)
  ──────────────────────
  PERMANENT exceptions   → skip immediately, no retry:
      IllegalArgumentException, IllegalStateException,
      FlatFileParseException, DataIntegrityViolationException

  TRANSIENT exceptions   → retry up to retry-limit, then skip:
      SQLTransientException, TransientDataAccessException

  If using JdbcCursorItemReader: omit retry-limit and
  retryable-exception-classes entirely (cursor state is corrupted by
  a failed read — retry is architecturally wrong).
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:batch="http://www.springframework.org/schema/batch"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
               https://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/batch
               https://www.springframework.org/schema/batch/spring-batch.xsd">

    <!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║  VARIANT A — Single-threaded chunk step                                 ║
    ╚══════════════════════════════════════════════════════════════════════════╝
    Use this for:
      - Any FlatFile or Jdbc reader when simplicity is preferred
      - JdbcCursorItemReader (NOT safe to share across threads)
      - Small-to-medium volumes where single-threaded throughput is sufficient
    -->

    <!-- ================================================================
         Reader
         - Use scope="step" whenever the bean needs access to jobParameters
           or stepExecutionContext (via SpEL #{jobParameters['key']}).
         - Remove scope="step" for beans that need no dynamic wiring.

         Common choices:
           FlatFileItemReader          — reads CSV / fixed-width file
           JdbcCursorItemReader        — reads a JDBC ResultSet (cursor)
           JdbcPagingItemReader        — reads DB rows page-by-page (thread-safe)
         ================================================================ -->
    <!-- TODO: replace the bean class and configure for your use case -->
    <bean id="templateItemReader"
          class="org.springframework.batch.infrastructure.item.file.FlatFileItemReader"
          scope="step">
        <!-- TODO: set resource, lineMapper, linesToSkip, etc. -->
        <!--
          SB6: no-arg constructor removed — lineMapper is now a required constructor argument.
          resource, linesToSkip, saveState, etc. remain as <property> setters.
        -->
        <!--
        <constructor-arg name="lineMapper">
            <bean class="org.springframework.batch.infrastructure.item.file.mapping.DefaultLineMapper">
                <property name="lineTokenizer">
                    <bean class="org.springframework.batch.infrastructure.item.file.transform.DelimitedLineTokenizer">
                        <property name="delimiter" value=","/>
                        <property name="names"     value="field1,field2,field3"/>
                    </bean>
                </property>
                <property name="fieldSetMapper">
                    <bean class="com.example.batch.yourpackage.YourFieldSetMapper"/>
                </property>
            </bean>
        </constructor-arg>
        <property name="resource"    value="file:${batch.template.inputDir}/input.csv"/>
        <property name="linesToSkip" value="1"/>
        <property name="saveState"   value="false"/>
        -->
    </bean>

    <!-- ================================================================
         Processor (optional — delete if no transformation is needed)
         - Must be stateless to be safely shared across chunk threads.
         - Implement ItemProcessor<INPUT, OUTPUT>.
         - Return null to filter an item (it is skipped, not counted as error).
         ================================================================ -->
    <!-- TODO: replace with your processor class, or remove entirely -->
    <bean id="templateItemProcessor"
          class="com.example.batch.yourpackage.YourItemProcessor"/>

    <!-- ================================================================
         Writer
         Common choices:
           FlatFileItemWriter     — writes CSV / fixed-width file
           JdbcBatchItemWriter    — batch INSERT / MERGE using JDBC
         ================================================================ -->
    <!-- TODO: replace the bean class and configure for your use case -->
    <bean id="templateItemWriter"
          class="org.springframework.batch.infrastructure.item.database.JdbcBatchItemWriter">
        <property name="dataSource" ref="dataSource"/>
        <!-- TODO: replace with your SQL -->
        <!--
        <property name="sql">
            <value>
                INSERT INTO YOUR_TABLE (col1, col2)
                VALUES (:field1, :field2)
            </value>
        </property>
        <property name="itemSqlParameterSourceProvider">
            <bean class="org.springframework.batch.infrastructure.item.database.BeanPropertyItemSqlParameterSourceProvider"/>
        </property>
        <property name="assertUpdates" value="false"/>
        -->
    </bean>

    <!-- ================================================================
         JOB DEFINITION (Variant A — single-threaded)
         ================================================================ -->
    <!-- TODO: rename the job id to match your job name -->
    <batch:job id="templateJob" restartable="true">

        <!-- TODO: keep or replace with a custom validator -->
        <batch:validator ref="templateJobParameterValidator"/>

        <batch:listeners>
            <batch:listener ref="jobStatisticsListener"/>
        </batch:listeners>

        <!-- ============================================================
             STEP 1 — Single-threaded chunk
             ============================================================ -->
        <!-- TODO: rename step id -->
        <batch:step id="templateChunkStep" next="statisticsAndEmailStep">
            <batch:tasklet transaction-manager="transactionManager">

                <!-- TODO: adjust commit-interval, skip-limit, retry-limit -->
                <batch:chunk reader="templateItemReader"
                             processor="templateItemProcessor"
                             writer="templateItemWriter"
                             commit-interval="${batch.template.commitInterval:100}"
                             skip-limit="50"
                             retry-limit="3">

                    <!-- PERMANENT: bad data — skip without retry -->
                    <batch:skippable-exception-classes>
                        <batch:include class="java.lang.IllegalArgumentException"/>
                        <batch:include class="java.lang.IllegalStateException"/>
                        <batch:include class="org.springframework.batch.infrastructure.item.file.FlatFileParseException"/>
                        <batch:include class="org.springframework.dao.DataIntegrityViolationException"/>
                        <batch:include class="java.sql.SQLTransientException"/>
                        <batch:include class="org.springframework.dao.TransientDataAccessException"/>
                    </batch:skippable-exception-classes>

                    <!-- TRANSIENT: retry DB errors before counting as a skip -->
                    <batch:retryable-exception-classes>
                        <batch:include class="java.sql.SQLTransientException"/>
                        <batch:include class="org.springframework.dao.TransientDataAccessException"/>
                    </batch:retryable-exception-classes>

                </batch:chunk>

                <batch:listeners>
                    <batch:listener ref="stepStatisticsListener"/>
                    <batch:listener ref="stepErrorCollector"/>
                </batch:listeners>

            </batch:tasklet>
        </batch:step>

        <!-- LAST STEP — Statistics report + email (keep as-is) -->
        <batch:step id="statisticsAndEmailStep">
            <batch:tasklet ref="statisticsAndEmailTasklet"
                           transaction-manager="transactionManager"/>
        </batch:step>

    </batch:job>


    <!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║  VARIANT B — Multi-threaded chunk step  (delete if not needed)          ║
    ╚══════════════════════════════════════════════════════════════════════════╝
    Use this for:
      - High-volume data with a thread-safe reader (JdbcPagingItemReader or
        SynchronizedItemStreamReader wrapping FlatFileItemReader)
      - When restart granularity at the chunk level is acceptable
      - Reader MUST be thread-safe:
          FlatFileItemReader    → wrap with SynchronizedItemStreamReader
          JdbcCursorItemReader  → use JdbcPagingItemReader instead
          JdbcPagingItemReader  → safe as-is
      - Add saveState="false" to all ItemStream beans (reader + writer)

    Required changes vs Variant A:
      1. Add SynchronizedItemStreamReader wrapper around FlatFileItemReader, OR
         use JdbcPagingItemReader directly
      2. Wrap FlatFileItemWriter with SynchronizedItemStreamWriter
      3. Add saveState="false" to reader and writer delegates
      4. Add task-executor to <batch:tasklet>
      5. Add the thread pool bean below

    -->
    <!--
      SB6: SynchronizedItemStreamReader and SynchronizedItemStreamWriter lost their no-arg
      constructors — delegate is now a required constructor argument.
    -->
    <!--
    <bean id="templateSyncReader"
          class="org.springframework.batch.infrastructure.item.support.SynchronizedItemStreamReader"
          scope="step">
        <constructor-arg name="delegate" ref="templateItemReader"/>
    </bean>

    <bean id="templateSyncWriter"
          class="org.springframework.batch.infrastructure.item.support.SynchronizedItemStreamWriter"
          scope="step">
        <constructor-arg name="delegate" ref="templateItemWriter"/>
    </bean>

    <bean id="templateTaskExecutor" parent="abstractStepTaskExecutor">
        <property name="corePoolSize"     value="${batch.template.threadCount:4}"/>
        <property name="maxPoolSize"      value="${batch.template.threadCount:4}"/>
        <property name="threadNamePrefix" value="template-worker-"/>
    </bean>
    -->
    <!--
    In the job definition, change the tasklet element to:
        <batch:tasklet transaction-manager="transactionManager"
                       task-executor="templateTaskExecutor">
    And reference templateSyncReader / templateSyncWriter instead.
    -->


    <!--
    ╔══════════════════════════════════════════════════════════════════════════╗
    ║  VARIANT C — Partitioned step  (delete if not needed)                   ║
    ╚══════════════════════════════════════════════════════════════════════════╝
    Use this for:
      - High-volume DB reads where work can be split by ID range
      - Best restart isolation: only failed partitions re-execute
      - Each worker step is completely independent — no shared reader/writer
        so NO synchronization wrappers are needed
      - Works well with JdbcCursorItemReader (safe inside a single worker)

    Required changes vs Variant A:
      1. Add ColumnRangePartitioner bean (step-scoped)
      2. Add TaskExecutorPartitionHandler bean
      3. Replace single chunk step with manager + worker step pair
      4. Use #{stepExecutionContext['minId']} / maxId in reader SQL
      5. Use #{stepExecutionContext['partitionNumber']} in writer resource name

    See partitioned-db-to-file-job.xml for a complete worked example.
    -->
    <!--
    <bean id="templatePartitioner"
          class="com.example.batch.support.ColumnRangePartitioner"
          scope="step">
        <property name="dataSource"   ref="dataSource"/>
        <property name="table"        value="YOUR_TABLE"/>
        <property name="column"       value="id"/>
        <property name="whereClause"  value="status = 'PENDING'"/>
    </bean>

    <bean id="templatePartitionHandler"
          class="org.springframework.batch.core.partition.support.TaskExecutorPartitionHandler">
        <property name="taskExecutor" ref="templatePartitionExecutor"/>
        <property name="step"         ref="templateWorkerStep"/>
        <property name="gridSize"     value="${batch.template.gridSize:4}"/>
    </bean>

    <bean id="templatePartitionExecutor" parent="abstractStepTaskExecutor">
        <property name="corePoolSize"     value="${batch.template.gridSize:4}"/>
        <property name="maxPoolSize"      value="${batch.template.gridSize:4}"/>
        <property name="threadNamePrefix" value="template-partition-"/>
    </bean>
    -->
    <!--
    In the job definition, replace the chunk step with:

    <batch:step id="templateManagerStep" next="statisticsAndEmailStep">
        <batch:partition step="templateWorkerStep"
                         partitioner="templatePartitioner"
                         handler="templatePartitionHandler"/>
        <batch:listeners>
            <batch:listener ref="stepStatisticsListener"/>
        </batch:listeners>
    </batch:step>

    And add a worker step outside the job:

    <batch:step id="templateWorkerStep">
        <batch:tasklet transaction-manager="transactionManager">
            <batch:chunk reader="templateItemReader"
                         writer="templateItemWriter"
                         commit-interval="${batch.template.commitInterval:100}"
                         skip-limit="50">
                ... skippable-exception-classes ...
            </batch:chunk>
            <batch:listeners>
                <batch:listener ref="stepErrorCollector"/>
            </batch:listeners>
        </batch:tasklet>
    </batch:step>
    -->


    <!-- ================================================================
         Parameter validator
         TODO: add the required parameter names for your job, or delete
         if the job takes no parameters.
         ================================================================ -->
    <bean id="templateJobParameterValidator"
          class="com.example.batch.support.BatchJobParameterValidator">
        <property name="requiredParams">
            <set>
                <!-- TODO: add required parameters -->
                <value>batchDate</value>
            </set>
        </property>
    </bean>

</beans>
