<?xml version="1.0" encoding="UTF-8"?>
<!--
  batch-infrastructure.xml
  ========================
  Core Spring Batch infrastructure beans:
    - HikariCP primaryDataSource   (MSSQL — main business DB + Batch metadata)
    - HikariCP secondaryDataSource (MSSQL — reporting / secondary business DB)
    - DataSourceTransactionManager per datasource
    - JobRepository        (persists batch metadata — uses primaryDataSource)
    - JobLauncher          (synchronous)
    - JobExplorer          (read-only execution history)
    - Auto-creates BATCH_* schema on first run

  Multiple datasource usage in job XML:
    - Primary  : ref="dataSource"          + transaction-manager="transactionManager"
    - Secondary: ref="secondaryDataSource" + transaction-manager="secondaryTransactionManager"

  All connection values come from application.properties (or profile overrides)
  via PropertySourcesPlaceholderConfigurer.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:batch="http://www.springframework.org/schema/batch"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
               https://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
               https://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/batch
               https://www.springframework.org/schema/batch/spring-batch.xsd">

    <!-- ================================================================
         Property placeholder — resolves ${...} from application.properties.
         Properties injected by SpringBatchApplication.enrichEnvironment()
         (profile file, external file, CLI params) have higher priority.
         ================================================================ -->
    <context:property-placeholder
            location="classpath:application.properties"
            ignore-unresolvable="false"/>

    <!-- ================================================================
         PRIMARY DataSource — main business DB + Spring Batch metadata
         ================================================================ -->
    <bean id="dataSource"
          class="com.zaxxer.hikari.HikariDataSource"
          destroy-method="close">
        <property name="driverClassName"     value="${datasource.driverClassName}"/>
        <property name="jdbcUrl"             value="${datasource.url}"/>
        <property name="username"            value="${datasource.username}"/>
        <property name="password"            value="${datasource.password}"/>
        <property name="maximumPoolSize"     value="${datasource.pool.maxSize:10}"/>
        <property name="minimumIdle"         value="${datasource.pool.minIdle:2}"/>
        <property name="connectionTimeout"   value="${datasource.pool.connectionTimeoutMs:30000}"/>
        <property name="idleTimeout"         value="${datasource.pool.idleTimeoutMs:600000}"/>
        <property name="maxLifetime"         value="${datasource.pool.maxLifetimeMs:1800000}"/>
        <property name="poolName"            value="PrimaryPool"/>
        <property name="keepaliveTime"       value="60000"/>
        <property name="connectionTestQuery" value="SELECT 1"/>
    </bean>

    <!-- ================================================================
         SECONDARY DataSource — reporting / secondary business DB
         Point at a different server/database than the primary.
         Set datasource.secondary.url=<same as primary> if you only
         have one physical database but still want logical separation.
         ================================================================ -->
    <bean id="secondaryDataSource"
          class="com.zaxxer.hikari.HikariDataSource"
          destroy-method="close">
        <property name="driverClassName"     value="${datasource.secondary.driverClassName:${datasource.driverClassName}}"/>
        <property name="jdbcUrl"             value="${datasource.secondary.url}"/>
        <property name="username"            value="${datasource.secondary.username}"/>
        <property name="password"            value="${datasource.secondary.password}"/>
        <property name="maximumPoolSize"     value="${datasource.secondary.pool.maxSize:5}"/>
        <property name="minimumIdle"         value="${datasource.secondary.pool.minIdle:1}"/>
        <property name="connectionTimeout"   value="${datasource.pool.connectionTimeoutMs:30000}"/>
        <property name="idleTimeout"         value="${datasource.pool.idleTimeoutMs:600000}"/>
        <property name="maxLifetime"         value="${datasource.pool.maxLifetimeMs:1800000}"/>
        <property name="poolName"            value="SecondaryPool"/>
        <property name="keepaliveTime"       value="60000"/>
        <property name="connectionTestQuery" value="SELECT 1"/>
    </bean>

    <!-- ================================================================
         Transaction Managers — one per datasource.
         transactionManager (primary) is used by:
           - Spring Batch JobRepository / step metadata
           - All jobs that use dataSource
         secondaryTransactionManager is used by:
           - Steps that read/write exclusively via secondaryDataSource
         ================================================================ -->
    <bean id="transactionManager"
          class="org.springframework.jdbc.datasource.DataSourceTransactionManager">
        <property name="dataSource" ref="dataSource"/>
    </bean>

    <bean id="secondaryTransactionManager"
          class="org.springframework.jdbc.datasource.DataSourceTransactionManager">
        <property name="dataSource" ref="secondaryDataSource"/>
    </bean>

    <!-- ================================================================
         Spring Batch schema auto-creation
         continueOnError="true" silently ignores "table already exists"
         Set batch.schema.initialize=false once BATCH_* tables are in place.
         ================================================================ -->
    <bean id="batchSchemaInitializer"
          class="org.springframework.jdbc.datasource.init.DataSourceInitializer">
        <property name="dataSource" ref="dataSource"/>
        <property name="enabled"    value="${batch.schema.initialize:true}"/>
        <property name="databasePopulator">
            <bean class="org.springframework.jdbc.datasource.init.ResourceDatabasePopulator">
                <property name="continueOnError"    value="true"/>
                <property name="ignoreFailedDrops"  value="true"/>
                <property name="scripts">
                    <list>
                        <!-- Spring Batch 5 ships this SQL for SQL Server -->
                        <value>classpath:org/springframework/batch/core/schema-sqlserver.sql</value>
                    </list>
                </property>
            </bean>
        </property>
    </bean>

    <!-- ================================================================
         Custom run-statistics schema
         Idempotent IF NOT EXISTS guards in schema-batch-stats.sql make
         continueOnError="true" a belt-and-suspenders safety measure.
         Set batch.stats.schema.initialize=false once tables are in place.
         ================================================================ -->
    <bean id="statsSchemaInitializer"
          class="org.springframework.jdbc.datasource.init.DataSourceInitializer">
        <property name="dataSource" ref="dataSource"/>
        <property name="enabled"    value="${batch.stats.schema.initialize:true}"/>
        <property name="databasePopulator">
            <bean class="org.springframework.jdbc.datasource.init.ResourceDatabasePopulator">
                <property name="continueOnError"   value="true"/>
                <property name="ignoreFailedDrops" value="true"/>
                <property name="scripts">
                    <list>
                        <value>classpath:schema-batch-stats.sql</value>
                    </list>
                </property>
            </bean>
        </property>
    </bean>

    <!-- ================================================================
         JobRunStatsRepository — persists aggregated run stats + step stats.
         Pruning of records older than batch.stats.retention.days is
         performed automatically after each save.
         ================================================================ -->
    <bean id="jobRunStatsRepository"
          class="com.example.batch.repository.JobRunStatsRepository">
        <property name="dataSource"    ref="dataSource"/>
        <property name="retentionDays" value="${batch.stats.retention.days:7}"/>
    </bean>

    <!-- ================================================================
         Job Repository — persists job / step execution metadata
         The batchSchemaInitializer bean ensures tables exist first.
         ================================================================ -->
    <batch:job-repository
            id="jobRepository"
            data-source="dataSource"
            transaction-manager="transactionManager"
            isolation-level-for-create="READ_COMMITTED"
            table-prefix="BATCH_"
            max-varchar-length="1000"/>

    <!-- ================================================================
         Job Launcher — synchronous (blocks until job finishes)
         Swap SyncTaskExecutor for ThreadPoolTaskExecutor for async runs.
         ================================================================ -->
    <bean id="jobLauncher"
          class="org.springframework.batch.core.launch.support.TaskExecutorJobLauncher">
        <property name="jobRepository" ref="jobRepository"/>
        <property name="taskExecutor">
            <bean class="org.springframework.core.task.SyncTaskExecutor"/>
        </property>
    </bean>

    <!-- ================================================================
         Job Explorer — read-only view of execution history
         ================================================================ -->
    <bean id="jobExplorer"
          class="org.springframework.batch.core.explore.support.JobExplorerFactoryBean">
        <property name="dataSource"         ref="dataSource"/>
        <property name="transactionManager" ref="transactionManager"/>
        <property name="tablePrefix"        value="BATCH_"/>
    </bean>

</beans>
