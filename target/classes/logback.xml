<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ================================================================
         Console appender — structured, readable format
         ================================================================ -->
    <!--
         %X{correlationId:-NO_ID}  — MDC value set by SpringBatchApplication per run.
         %X{jobName:-UNKNOWN}      — MDC value set at job launch.
         These appear in every log line, making it trivial to grep a single run.
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{correlationId:-NO_ID}] [%thread] %-5level %-35logger{35} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================
         Rolling file appender — one file per day, keep 30 days
         ================================================================ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/spring-batch.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/spring-batch.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%X{correlationId:-NO_ID}] [%thread] %-5level %-35logger{35} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================
         Logger levels
         ================================================================ -->
    <!-- Application code — DEBUG for full visibility -->
    <logger name="com.example.batch" level="DEBUG"/>

    <!-- Spring Batch internals — INFO to see step/job lifecycle events -->
    <logger name="org.springframework.batch" level="INFO"/>

    <!-- Spring Framework — WARN to suppress routine wiring noise -->
    <logger name="org.springframework" level="WARN"/>

    <!-- HikariCP — INFO for pool lifecycle events -->
    <logger name="com.zaxxer.hikari" level="INFO"/>

    <!-- SQL Server JDBC driver — WARN -->
    <logger name="com.microsoft.sqlserver" level="WARN"/>

    <!-- ================================================================
         Root logger
         ================================================================ -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
