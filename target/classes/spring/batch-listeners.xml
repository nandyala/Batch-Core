<?xml version="1.0" encoding="UTF-8"?>
<!--
  batch-listeners.xml
  ===================
  Reusable listener and tasklet beans any job can reference.

  ┌─────────────────────────────────────────────────────────────────────┐
  │  HOW TO USE IN ANY JOB                                              │
  ├─────────────────────────────────────────────────────────────────────┤
  │                                                                     │
  │  1. Job-boundary logging  (start / end status):                     │
  │       <batch:job id="myJob">                                        │
  │         <batch:listeners>                                           │
  │           <batch:listener ref="jobStatisticsListener"/>             │
  │         </batch:listeners>                                          │
  │         ...                                                         │
  │       </batch:job>                                                  │
  │                                                                     │
  │  2. Per-step count logging + error capture (attach to chunk step):  │
  │       <batch:tasklet ...>                                           │
  │         <batch:chunk .../>                                          │
  │         <batch:listeners>                                           │
  │           <batch:listener ref="stepStatisticsListener"/>            │
  │           <batch:listener ref="stepErrorCollector"/>                │
  │         </batch:listeners>                                          │
  │       </batch:tasklet>                                              │
  │                                                                     │
  │  3. Statistics report + email  (ALWAYS the last step):              │
  │       <batch:step id="lastBusinessStep"                             │
  │                   next="statisticsAndEmailStep"> ... </batch:step>  │
  │       <batch:step id="statisticsAndEmailStep">                      │
  │         <batch:tasklet ref="statisticsAndEmailTasklet"              │
  │                        transaction-manager="transactionManager"/>   │
  │       </batch:step>                                                 │
  │                                                                     │
  └─────────────────────────────────────────────────────────────────────┘
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
               https://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- ================================================================
         1. StepStatisticsListener
            Logs read / write / skip / filter counts after each step.
            Singleton — safe to share across jobs and steps.
         ================================================================ -->
    <bean id="stepStatisticsListener"
          class="com.example.batch.listener.StepStatisticsListener"/>

    <!-- ================================================================
         2. JobStatisticsListener
            Logs job name + final status at start and end.
         ================================================================ -->
    <bean id="jobStatisticsListener"
          class="com.example.batch.listener.JobStatisticsListener"/>

    <!-- ================================================================
         3. StepErrorCollector
            Captures skip events (TRANSIENT + PERMANENT) and stores up to
            10 error messages per step in StepExecution.ExecutionContext.
            StatisticsAndEmailTasklet reads these after all steps complete.

            Add to every chunk step's <batch:listeners>:
              <batch:listener ref="stepErrorCollector"/>
         ================================================================ -->
    <bean id="stepErrorCollector"
          class="com.example.batch.listener.StepErrorCollector"/>

    <!-- ================================================================
         4. BatchJobParameterValidator
            Validates common job parameters (batchDate format, etc.).
            Reference from <batch:job><batch:validator ref="..."/>.
            For per-job required params, declare a separate bean in the
            job XML with a <property name="requiredParams"> override.
         ================================================================ -->
    <bean id="batchJobParameterValidator"
          class="com.example.batch.support.BatchJobParameterValidator"/>

    <!-- ================================================================
         5. StatisticsAndEmailTasklet
            Declare as the LAST <batch:step> of every job.
            Responsibilities:
              a) Aggregate counts from all preceding steps
              b) Collect errors from StepErrorCollector
              c) Print business-friendly report to log
              d) Send HTML email report (if batch.email.enabled=true)
              e) Persist run summary to BATCH_JOB_RUN_STATS (7-day retention)

            To send to a different address for a specific job, declare
            a second bean in the job XML:

              <bean id="invoiceJobStatsTasklet"
                    class="com.example.batch.tasklet.StatisticsAndEmailTasklet">
                <property name="emailNotificationService" ref="emailNotificationService"/>
                <property name="reportToEmail"    value="finance-team@example.com"/>
                <property name="jobRunStatsRepository" ref="jobRunStatsRepository"/>
              </bean>
         ================================================================ -->
    <bean id="statisticsAndEmailTasklet"
          class="com.example.batch.tasklet.StatisticsAndEmailTasklet">
        <property name="emailNotificationService" ref="emailNotificationService"/>
        <property name="reportToEmail"            value="${batch.report.email}"/>
        <!-- Feature flag: set batch.email.enabled=false to skip email -->
        <property name="emailEnabled"             value="${batch.email.enabled:true}"/>
        <!-- DB persistence: wired from batch-infrastructure.xml -->
        <property name="jobRunStatsRepository"    ref="jobRunStatsRepository"/>
    </bean>

</beans>
